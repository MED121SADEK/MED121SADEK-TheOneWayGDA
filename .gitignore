node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ---------- Next.js ----------
/.next/
/out/

# ---------- Production ----------
/build

# ---------- Testing ----------
/coverage
/__tests__/coverage
.nyc_output

# ---------- TypeScript ----------
*.tsbuildinfo
next-env.d.ts

# ---------- Environment Variables ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ---------- Vercel ----------
.vercel

# ---------- Database (SQLite / Prisma) ----------
*.db
*.db-journal
*.db-wal
*.db-shm
db/
prisma/migrations/migration_lock.toml

# ---------- Logs ----------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dev.log
dev.out.log
server.log

# ---------- OS / Editor Files ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pem
*.swp
*.swo
*~
.idea/
.vscode/
*.code-workspace
*.sublime-project
*.sublime-workspace

# ---------- AI / Internal Config ----------
.claude
.z-ai-config
prompt
skills/

# ---------- Debug / Temp ----------
test
local-*
.cache/
tmp/
temp/
*.bak
*.tmp

# ---------- Caddy ----------
Caddyfile

# ---------- Docker (optional) ----------
docker-compose.override.yml

# ---------- Search indexing ----------
.csearchindex

# ---------- Lock files (keep package-lock, ignore others) ----------
yarn.lock
pnpm-lock.yaml
