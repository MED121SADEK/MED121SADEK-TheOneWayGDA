// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        String
  variables   String
  outputs     String?
  shared      Boolean  @default(false)
  sharedWith  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(cuid())
  type      String   @default("community") // "community" | "news"
  title     String
  content   String
  author    String   // visitor email or "TheOneWayGDA"
  authorName String?
  imageUrl  String?
  sourceUrl String?  // external news URL
  sourceName String? // e.g. "TechCrunch"
  tags      String?  // JSON array of tag strings
  likes     Int      @default(0)
  comments  Int      @default(0)
  reposts   Int      @default(0)
  saves     Int      @default(0)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([author])
  @@index([createdAt])
  @@index([featured])

  postComments  PostComment[]
  interactions  PostInteraction[]
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String   // visitor email
  authorName String?
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([createdAt])
}

model PostInteraction {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String   // visitor email
  type      String   // "like" | "save"
  createdAt DateTime @default(now())

  @@unique([postId, visitorId, type])
  @@index([postId])
  @@index([visitorId])
}

model Visitor {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  visitorType String   @default("general")
  status      String   @default("pending")
  ipAddress   String?
  userAgent   String?
  path        String?
  notes       String?
  country     String?
  language    String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @updatedAt

  @@index([createdAt])
  @@index([visitorType])
  @@index([status])
}

model AiModel {
  @@map("AIModel")
  id            String   @id @default(cuid())
  name          String
  provider      String
  description   String?
  modelType     String   @default("chat")
  contextWindow Int      @default(8192)
  parameters    String?
  releaseDate   String?
  isActive      Boolean  @default(true)
  websiteUrl    String?
  apiDocsUrl    String?
  tags          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, provider])
  @@index([provider])
  @@index([modelType])
  @@index([isActive])

  benchmarkScores BenchmarkScore[]
  pricing         ModelPricing[]
  liveMetrics     LiveMetric[]
}

model BenchmarkScore {
  id        String   @id @default(cuid())
  modelId   String
  model     AiModel       @relation(fields: [modelId], references: [id], onDelete: Cascade)
  benchmark String
  score     Float
  maxScore  Float    @default(100)
  source    String   @default("verified")
  sourceUrl String?
  version   String   @default("latest")
  sampledAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, benchmark, version])
  @@index([modelId])
  @@index([benchmark])
  @@index([score])
}

model ModelPricing {
  id              String   @id @default(cuid())
  modelId         String
  model           AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  provider        String
  inputPrice      Float
  outputPrice     Float
  batchInputPrice Float?
  batchOutputPrice Float?
  currency        String   @default("USD")
  effectiveDate   DateTime @default(now())
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([modelId])
  @@index([provider])
  @@index([isActive])
}

model LiveMetric {
  id           String   @id @default(cuid())
  modelId      String
  model        AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  prompt       String
  response     String?
  latencyMs    Int?
  tps          Float?
  inputTokens  Int?
  outputTokens Int?
  status       String   @default("pending")
  errorMessage String?
  testedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([modelId])
  @@index([testedAt])
  @@index([status])
}

model LeaderboardSnapshot {
  id           String   @id @default(cuid())
  benchmark    String
  ranking      String
  snapshotDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([benchmark])
  @@index([snapshotDate])
}

model CronJob {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String
  interval    String    @default("1h")
  status      String    @default("idle")
  lastRun     DateTime?
  nextRun     DateTime?
  lastError   String?
  runCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([nextRun])
}