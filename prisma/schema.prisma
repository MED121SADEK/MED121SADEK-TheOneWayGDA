// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        String
  variables   String
  outputs     String?
  shared      Boolean  @default(false)
  sharedWith  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(cuid())
  type      String   @default("community") // "community" | "news"
  title     String
  content   String
  author    String   // visitor email or "TheOneWayGDA"
  authorName String?
  imageUrl  String?
  sourceUrl String?  // external news URL
  sourceName String? // e.g. "TechCrunch"
  tags      String?  // JSON array of tag strings
  likes     Int      @default(0)
  comments  Int      @default(0)
  reposts   Int      @default(0)
  saves     Int      @default(0)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([author])
  @@index([createdAt])
  @@index([featured])

  postComments  PostComment[]
  interactions  PostInteraction[]
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String   // visitor email
  authorName String?
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([createdAt])
}

model PostInteraction {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String   // visitor email
  type      String   // "like" | "save"
  createdAt DateTime @default(now())

  @@unique([postId, visitorId, type])
  @@index([postId])
  @@index([visitorId])
}

model UserFollow {
  id          String   @id @default(cuid())
  followerId  String   // visitor email of the follower
  followingId String   // visitor email being followed
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model TopicFollow {
  id        String   @id @default(cuid())
  visitorId String   // visitor email
  topic     String   // "AI" | "Research" | "Innovation" | specific tags
  createdAt DateTime @default(now())

  @@unique([visitorId, topic])
  @@index([visitorId])
  @@index([topic])
}

model Visitor {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  visitorType String   @default("general")
  status      String   @default("pending")
  ipAddress   String?
  userAgent   String?
  path        String?
  notes       String?
  country     String?
  language    String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @updatedAt

  @@index([createdAt])
  @@index([visitorType])
  @@index([status])
}

model AiModel {
  @@map("AIModel")
  id            String   @id @default(cuid())
  name          String
  provider      String
  description   String?
  modelType     String   @default("chat")
  contextWindow Int      @default(8192)
  parameters    String?
  releaseDate   String?
  isActive      Boolean  @default(true)
  websiteUrl    String?
  apiDocsUrl    String?
  tags          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, provider])
  @@index([provider])
  @@index([modelType])
  @@index([isActive])

  benchmarkScores BenchmarkScore[]
  pricing         ModelPricing[]
  liveMetrics     LiveMetric[]
}

model BenchmarkScore {
  id        String   @id @default(cuid())
  modelId   String
  model     AiModel       @relation(fields: [modelId], references: [id], onDelete: Cascade)
  benchmark String
  score     Float
  maxScore  Float    @default(100)
  source    String   @default("verified")
  sourceUrl String?
  version   String   @default("latest")
  sampledAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, benchmark, version])
  @@index([modelId])
  @@index([benchmark])
  @@index([score])
}

model ModelPricing {
  id              String   @id @default(cuid())
  modelId         String
  model           AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  provider        String
  inputPrice      Float
  outputPrice     Float
  batchInputPrice Float?
  batchOutputPrice Float?
  currency        String   @default("USD")
  effectiveDate   DateTime @default(now())
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([modelId])
  @@index([provider])
  @@index([isActive])
}

model LiveMetric {
  id           String   @id @default(cuid())
  modelId      String
  model        AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  prompt       String
  response     String?
  latencyMs    Int?
  tps          Float?
  inputTokens  Int?
  outputTokens Int?
  status       String   @default("pending")
  errorMessage String?
  testedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([modelId])
  @@index([testedAt])
  @@index([status])
}

model LeaderboardSnapshot {
  id           String   @id @default(cuid())
  benchmark    String
  ranking      String
  snapshotDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([benchmark])
  @@index([snapshotDate])
}

model CronJob {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String
  interval    String    @default("1h")
  status      String    @default("idle")
  lastRun     DateTime?
  nextRun     DateTime?
  lastError   String?
  runCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([nextRun])
}

// ═══ AI Copilot & Automation ═══

model AiConversation {
  id          String   @id @default(cuid())
  sessionId   String
  visitorId   String?
  context     String   @default("general") // "workspace" | "leaderboard" | "community" | "general"
  title       String?
  messages    String   // JSON array of {role, content, timestamp}
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([visitorId])
  @@index([context])
}

model AutomationRule {
  id          String   @id @default(cuid())
  visitorId   String?
  name        String
  description String?
  trigger     String   // "schedule" | "event" | "manual" | "new_data"
  triggerConfig String // JSON: {cron?: string, eventType?: string, condition?: string}
  actions     String   // JSON array of {type: "clean"|"model"|"report"|"notify", config: {...}}
  isActive    Boolean  @default(true)
  lastRun     DateTime?
  nextRun     DateTime?
  runCount    Int      @default(0)
  lastStatus  String?  // "success" | "error"
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visitorId])
  @@index([isActive])
  @@index([nextRun])
}

model AutomationLog {
  id          String   @id @default(cuid())
  ruleId      String
  status      String   @default("pending") // "pending" | "running" | "success" | "error"
  input       String?  // JSON: trigger input data
  output      String?  // JSON: action results
  error       String?
  durationMs  Int?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([ruleId])
  @@index([status])
}

model AiSuggestion {
  id          String   @id @default(cuid())
  visitorId   String?
  context     String   // "workspace" | "leaderboard" | "data_prep" | "modeling" | "reporting"
  category    String   // "next_action" | "insight" | "optimization" | "template" | "learning"
  title       String
  content     String   // JSON: detailed suggestion data
  confidence  Float    @default(0.5)
  isAccepted  Boolean?
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([context])
  @@index([category])
  @@index([createdAt])
}

model UserPreference {
  id            String   @id @default(cuid())
  visitorId     String   @unique
  skillLevel    String   @default("intermediate") // "beginner" | "intermediate" | "expert"
  preferredLang String   @default("en")
  interfaceMode String   @default("standard") // "compact" | "standard" | "advanced"
  recentPages   String?  // JSON array of recent page paths
  frequentActions String? // JSON: {action: count} map
  theme         String   @default("dark")
  aiSensitivity Float    @default(0.7) // 0-1, how proactive AI should be
  notificationsEnabled Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([visitorId])
}

model AiAuditLog {
  id          String   @id @default(cuid())
  visitorId   String?
  action      String   // "suggestion_accepted" | "suggestion_dismissed" | "automation_run" | "ai_query" | "data_access"
  details     String   // JSON: full context of the action
  error       String?  // Error message if action failed
  inputData   String?  // JSON: what data the AI accessed
  outputData  String?  // JSON: what the AI produced
  model       String   @default("default") // which AI model was used
  tokensUsed  Int?
  durationMs  Int?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([action])
  @@index([createdAt])
}

// ═══ Workflow-Native Copilot ═══

model WorkflowPipeline {
  id               String   @id @default(cuid())
  visitorId        String?
  projectId        String?
  name             String
  description      String?
  intent           String   // User's high-level intent (e.g., "Analyze sales trends")
  steps            String   // JSON: ordered array of {id, type, name, config, status}
  status           String   @default("draft") // "draft" | "ready" | "running" | "completed" | "error"
  result           String?  // JSON: pipeline execution results
  executiveSummary String? // AI-generated executive summary
  tokensUsed       Int?
  durationMs       Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([visitorId])
  @@index([status])
}

model DecisionRecord {
  id              String   @id @default(cuid())
  visitorId       String?
  projectId       String?
  pipelineId      String?
  context         String   // "workspace" | "leaderboard" | "automation"
  question        String   // User's question/intent
  aiAnalysis      String   // JSON: AI's analysis and reasoning
  options         String?  // JSON: generated options
  selectedOption  String?
  outcome         String?  // JSON: what happened after decision
  confidence      Float?
  createdAt       DateTime @default(now())

  @@index([visitorId])
  @@index([context])
  @@index([createdAt])
}

// ═══ Community-Driven Learning ═══

model SharedWorkflow {
  id               String   @id @default(cuid())
  sourcePipelineId String?  // ID of the original WorkflowPipeline (if forked from one)
  author           String   // visitor email
  authorName       String?
  name             String
  description      String?
  intent           String?  // Snapshot of the original intent
  steps            String   // JSON: snapshot of pipeline steps
  category         String   @default("general") // "data_analysis" | "reporting" | "ml_pipeline" | "data_cleaning" | "benchmarking" | "general"
  difficulty       String   @default("intermediate") // "beginner" | "intermediate" | "advanced"
  tags             String?  // JSON array of tag strings
  rating           Float    @default(0)
  ratingCount      Int      @default(0)
  usageCount       Int      @default(0)
  forkCount        Int      @default(0)
  isFeatured       Boolean  @default(false)
  isOfficial       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([author])
  @@index([category])
  @@index([difficulty])
  @@index([rating])
  @@index([usageCount])
  @@index([isFeatured])
}

model BenchmarkConfig {
  id               String   @id @default(cuid())
  sourceConfigId   String?  // ID of the config this was forked from
  author           String   // visitor email
  authorName       String?
  name             String
  description      String?
  category         String   @default("general") // "reasoning" | "coding" | "creative" | "math" | "multilingual" | "safety" | "general"
  difficulty       String   @default("intermediate") // "easy" | "intermediate" | "hard" | "expert"
  testPrompts      String   // JSON: array of {prompt, expectedKeywords?, expectedLength?}
  evaluationCriteria String // JSON: {metrics: [...], weights: {...}, rubric: string}
  expectedOutputs  String?  // JSON: array of expected output patterns/keywords
  modelIds         String?  // JSON: array of model IDs this config has been tested against
  results          String?  // JSON: aggregated results per model
  rating           Float    @default(0)
  ratingCount      Int      @default(0)
  usageCount       Int      @default(0)
  forkCount        Int      @default(0)
  isFeatured       Boolean  @default(false)
  isOfficial       Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([author])
  @@index([category])
  @@index([difficulty])
  @@index([rating])
  @@index([usageCount])
  @@index([isFeatured])
}

model CommunityAnalysisTemplate {
  id                 String   @id @default(cuid())
  sourceTemplateId   String?  // ID of the template this was forked/improved from
  author             String   // visitor email
  authorName         String?
  name               String
  description        String?
  category           String   @default("statistical") // "statistical" | "machine_learning" | "data_cleaning" | "visualization" | "reporting" | "benchmarking"
  difficulty         String   @default("intermediate") // "beginner" | "intermediate" | "advanced"
  steps              String   // JSON: array of {id, order, name, description, type, config}
  requiredVariables  String?  // JSON array of required variable names
  estimatedDuration  String?  // e.g. "15 min", "1 hour", "2-3 hours"
  tags               String?  // JSON array of tag strings
  rating             Float    @default(0)
  ratingCount        Int      @default(0)
  usageCount         Int      @default(0)
  improvementCount   Int      @default(0)
  isFeatured         Boolean  @default(false)
  isOfficial         Boolean  @default(false)
  version            Int      @default(1)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([author])
  @@index([category])
  @@index([difficulty])
  @@index([rating])
  @@index([usageCount])
  @@index([isFeatured])
  @@index([isOfficial])
}

// ═══ MLOps — AI Prompt & Config Versioning ═══

model PromptVersion {
  id          String   @id @default(cuid())
  name        String
  version     String   // "v1.0.0", "v1.1.0"
  context     String   // "copilot" | "workflow" | "automation" | "governance"
  prompt      String   // The actual system prompt text
  description String?
  isActive    Boolean  @default(false)
  metadata    String?  // JSON: {tokens, testedAt, changelog}
  createdBy   String?  // visitor email or "system"
  createdAt   DateTime @default(now())

  @@unique([name, version])
  @@index([context])
  @@index([isActive])
}

model AiModelConfig {
  id            String   @id @default(cuid())
  name          String
  version       String
  model         String   // "default" | "gpt-4" | specific model identifier
  parameters    String   // JSON: {temperature, maxTokens, topP, ...}
  promptVersion String?
  isActive      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@unique([name, version])
  @@index([isActive])
}

model EvaluationRun {
  id            String   @id @default(cuid())
  configVersion String
  promptVersion String
  status        String   @default("pending") // "pending" | "running" | "completed" | "failed"
  metrics       String   // JSON: {accuracy, latencyMs, tokenUsage, userSatisfaction}
  testCases     Int      @default(0)
  passed        Int      @default(0)
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([configVersion])
  @@index([status])
}

// ═══ DevOps — Application Error Logging ═══

model AppErrorLog {
  id          String   @id @default(cuid())
  level       String   @default("error") // "error" | "warn" | "fatal"
  domain      String   @default("application") // "api" | "database" | "ai" | "auth" | "system"
  route       String?  // API route or page path where error occurred
  message     String   // Error message
  stack       String?  // Stack trace (truncated)
  requestId   String?  // Request ID for correlation
  statusCode  Int?     // HTTP status code (if applicable)
  method      String?  // HTTP method
  ipAddress   String?
  userAgent   String?
  metadata    String?  // JSON: additional context
  resolved    Boolean  @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([level])
  @@index([domain])
  @@index([route])
  @@index([createdAt])
  @@index([resolved])
}

model DeployLog {
  id          String   @id @default(cuid())
  environment String   @default("production") // "staging" | "production"
  version     String   // git SHA or version tag
  deployer    String?  // who triggered the deploy
  strategy    String   @default("rolling") // "rolling" | "blue-green" | "canary"
  status      String   @default("pending") // "pending" | "running" | "success" | "failed" | "rolled_back"
  durationMs  Int?
  backupPath  String?  // path to database backup
  rollbackTo  String?  // version rolled back to (if applicable)
  notes       String?
  createdAt   DateTime @default(now())
  completedAt DateTime?

  @@index([environment])
  @@index([status])
  @@index([createdAt])
}

// ═══ Verified Researchers & Institutions ═══

model VerifiedResearcher {
  id           String   @id @default(cuid())
  email        String   @unique           // visitor email or bot identifier (e.g. "THEONEWAYGDA_AI")
  displayName  String                      // public display name (e.g. "DeepMind Research")
  institution  String?                     // lab/company/institution name (e.g. "Google DeepMind")
  role         String?                     // role/title (e.g. "AI Lab", "Researcher", "News Bot")
  badgeType    String   @default("verified") // "verified" | "institution" | "official" | "bot"
  bio          String?                     // short description
  websiteUrl   String?
  verifiedBy   String?                     // admin who verified
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([badgeType])
  @@index([isActive])
  @@index([institution])
}

// ═══ Phase 1: Auth System & User Profiles ═══

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String?
  image           String?
  role            String    @default("user") // "user" | "pro" | "admin"
  bio             String?
  company         String?
  location        String?
  website         String?
  skills          String?   // JSON: ["statistics", "python", ...]
  preferences     String?   // JSON: {theme, language, notifications...}
  isOnboarded     Boolean   @default(false)
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastSeen        DateTime  @updatedAt

  @@index([role])
  @@index([isOnboarded])

  sessions UserSession[]
  activities UserActivity[]
  ownedTeams Team[] @relation("TeamOwner")
  teamMemberships TeamMember[] @relation("TeamMemberships")
  apiKeys      ApiKey[]
  usageRecords UsageRecord[]
  subscription Subscription?
  notifications Notification[]
}

model UserSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  ipAddress String?
  userAgent String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "login" | "project_created" | "analysis_run" | "report_generated" | "workflow_executed" | "automation_triggered" | "profile_updated"
  details   String?  // JSON: additional context
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

// ═══ Phase 2: Advanced Analytics Engine ═══

model AnalysisRun {
  id          String   @id @default(cuid())
  userId      String?
  projectId   String?
  name        String
  type        String   // "descriptive" | "inferential" | "regression" | "correlation" | "prediction" | "classification" | "clustering" | "time_series"
  status      String   @default("pending") // "pending" | "running" | "completed" | "error"
  inputData   String   // JSON: input data snapshot
  config      String?  // JSON: analysis configuration
  result      String?  // JSON: analysis results (statistics, p-values, r-squared, etc.)
  chartData   String?  // JSON: chart-ready data (for visualizations)
  summary     String?  // AI-generated summary of findings
  errorMessage String?
  durationMs  Int?
  aiModel     String?  // which AI model was used
  tokensUsed  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ═══ Phase 3: Collaboration & Teams ═══

model Team {
  id          String   @id @default(cuid())
  name        String
  description String?
  slug        String   @unique
  avatar      String?  // team logo/gradient color
  ownerId     String
  owner       User     @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  isPublic    Boolean  @default(false) // visible in team directory
  maxMembers  Int      @default(10)
  inviteCode  String   @unique // 8-char alphanumeric join code
  settings    String?  // JSON: {defaultRole, allowFork, requireApproval, ...}
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ownerId])
  @@index([isPublic])
  @@index([inviteCode])

  members     TeamMember[]
  invites     TeamInvite[]
  sharedItems TeamShare[]
  activity    TeamActivity[]
}

model TeamMember {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation("TeamMemberships", fields: [userId], references: [id], onDelete: Cascade)
  role        String   @default("member") // "owner" | "admin" | "member" | "viewer"
  nickname    String?
  joinedAt    DateTime @default(now())
  lastActive  DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
  @@index([role])
}

model TeamInvite {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy   String   // userId who sent the invite
  email       String?  // target email (for email invites)
  userId      String?  // target userId (for direct invites)
  role        String   @default("member")
  status      String   @default("pending") // "pending" | "accepted" | "rejected" | "expired"
  message     String?  // personal message from inviter
  expiresAt   DateTime // invite expiry
  createdAt   DateTime @default(now())
  respondedAt DateTime?

  @@index([teamId])
  @@index([email])
  @@index([userId])
  @@index([status])
  @@index([expiresAt])
}

model TeamShare {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sharedBy    String   // userId who shared
  resourceType String  // "workflow" | "analysis" | "project" | "benchmark_config" | "template"
  resourceId  String   // ID of the shared resource
  resourceName String  // snapshot of resource name
  description String?
  permissions String   @default("view") // JSON: ["view"] | ["view", "edit", "fork", "delete"]
  isPinned    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([resourceType])
  @@index([sharedBy])
  @@index([isPinned])
}

model TeamActivity {
  id          String   @id @default(cuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId      String   // user who performed the action
  userName    String?  // snapshot of user name
  type        String   // "member_joined" | "member_left" | "invite_sent" | "invite_accepted" | "resource_shared" | "resource_created" | "comment_added" | "team_updated"
  details     String?  // JSON: additional context
  createdAt   DateTime @default(now())

  @@index([teamId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
}

model TeamComment {
  id          String   @id @default(cuid())
  teamId      String
  shareId     String?  // nullable = general team comment, otherwise linked to a shared resource
  userId      String
  userName    String?
  content     String
  editedAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
  @@index([shareId])
  @@index([userId])
  @@index([createdAt])
}

// ═══ Phase 4: Monetization, API Keys & Notifications ═══

model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // human-readable label, e.g. "Production Key"
  prefix      String   // first 8 chars shown in UI, e.g. "onw_a3f8..."
  keyHash     String   // SHA-256 hash of the full key (never stored plain)
  scopes      String   @default("read") // JSON: ["read"] | ["read", "write", "admin"]
  rateLimit   Int      @default(100) // requests per minute
  lastUsed    DateTime?
  requestCount Int     @default(0)
  expiresAt   DateTime? // null = never expires
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([prefix])
  @@index([isActive])
}

model UsageRecord {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  apiKeyId    String?
  category    String   // "ai_query" | "workflow" | "analysis" | "api_call" | "export"
  operation   String?  // specific operation, e.g. "chat.completion" | "workflow.execute"
  tokensUsed  Int      @default(0)
  durationMs  Int?
  costUsd     Float    @default(0) // estimated cost in USD
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([apiKeyId])
  @@index([category])
  @@index([createdAt])
}

model Subscription {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan        String   @default("free") // "free" | "pro" | "enterprise"
  status      String   @default("active") // "active" | "past_due" | "canceled" | "trialing"
  stripeCustomerId   String? // Stripe customer ID (for future integration)
  stripeSubscriptionId String? // Stripe subscription ID
  currentPeriodStart DateTime @default(now())
  currentPeriodEnd   DateTime?
  trialEnd    DateTime?
  cancelAt    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([plan])
  @@index([status])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   // "team_invite" | "team_member_joined" | "resource_shared" | "usage_alert" | "system" | "billing"
  title       String
  message     String
  actionUrl   String?  // link to navigate to
  actionLabel String?  // CTA button text, e.g. "View Team"
  isRead      Boolean  @default(false)
  readAt      DateTime?
  metadata    String?  // JSON: additional context
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([type])
  @@index([createdAt])
}