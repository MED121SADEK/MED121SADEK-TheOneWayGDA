// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        String
  variables   String
  outputs     String?
  shared      Boolean  @default(false)
  sharedWith  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunityPost {
  id        String   @id @default(cuid())
  type      String   @default("community") // "community" | "news"
  title     String
  content   String
  author    String   // visitor email or "TheOneWayGDA"
  authorName String?
  imageUrl  String?
  sourceUrl String?  // external news URL
  sourceName String? // e.g. "TechCrunch"
  tags      String?  // JSON array of tag strings
  likes     Int      @default(0)
  comments  Int      @default(0)
  reposts   Int      @default(0)
  saves     Int      @default(0)
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([author])
  @@index([createdAt])
  @@index([featured])

  postComments  PostComment[]
  interactions  PostInteraction[]
}

model PostComment {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author    String   // visitor email
  authorName String?
  content   String
  createdAt DateTime @default(now())

  @@index([postId])
  @@index([createdAt])
}

model PostInteraction {
  id        String   @id @default(cuid())
  postId    String
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  visitorId String   // visitor email
  type      String   // "like" | "save"
  createdAt DateTime @default(now())

  @@unique([postId, visitorId, type])
  @@index([postId])
  @@index([visitorId])
}

model Visitor {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  visitorType String   @default("general")
  status      String   @default("pending")
  ipAddress   String?
  userAgent   String?
  path        String?
  notes       String?
  country     String?
  language    String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @updatedAt

  @@index([createdAt])
  @@index([visitorType])
  @@index([status])
}

model AiModel {
  @@map("AIModel")
  id            String   @id @default(cuid())
  name          String
  provider      String
  description   String?
  modelType     String   @default("chat")
  contextWindow Int      @default(8192)
  parameters    String?
  releaseDate   String?
  isActive      Boolean  @default(true)
  websiteUrl    String?
  apiDocsUrl    String?
  tags          String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([name, provider])
  @@index([provider])
  @@index([modelType])
  @@index([isActive])

  benchmarkScores BenchmarkScore[]
  pricing         ModelPricing[]
  liveMetrics     LiveMetric[]
}

model BenchmarkScore {
  id        String   @id @default(cuid())
  modelId   String
  model     AiModel       @relation(fields: [modelId], references: [id], onDelete: Cascade)
  benchmark String
  score     Float
  maxScore  Float    @default(100)
  source    String   @default("verified")
  sourceUrl String?
  version   String   @default("latest")
  sampledAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([modelId, benchmark, version])
  @@index([modelId])
  @@index([benchmark])
  @@index([score])
}

model ModelPricing {
  id              String   @id @default(cuid())
  modelId         String
  model           AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  provider        String
  inputPrice      Float
  outputPrice     Float
  batchInputPrice Float?
  batchOutputPrice Float?
  currency        String   @default("USD")
  effectiveDate   DateTime @default(now())
  isActive        Boolean  @default(true)
  updatedAt       DateTime @updatedAt
  createdAt       DateTime @default(now())

  @@index([modelId])
  @@index([provider])
  @@index([isActive])
}

model LiveMetric {
  id           String   @id @default(cuid())
  modelId      String
  model        AiModel @relation(fields: [modelId], references: [id], onDelete: Cascade)
  prompt       String
  response     String?
  latencyMs    Int?
  tps          Float?
  inputTokens  Int?
  outputTokens Int?
  status       String   @default("pending")
  errorMessage String?
  testedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([modelId])
  @@index([testedAt])
  @@index([status])
}

model LeaderboardSnapshot {
  id           String   @id @default(cuid())
  benchmark    String
  ranking      String
  snapshotDate DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([benchmark])
  @@index([snapshotDate])
}

model CronJob {
  id          String    @id @default(cuid())
  name        String    @unique
  type        String
  interval    String    @default("1h")
  status      String    @default("idle")
  lastRun     DateTime?
  nextRun     DateTime?
  lastError   String?
  runCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([nextRun])
}

// ═══ AI Copilot & Automation ═══

model AiConversation {
  id          String   @id @default(cuid())
  sessionId   String
  visitorId   String?
  context     String   @default("general") // "workspace" | "leaderboard" | "community" | "general"
  title       String?
  messages    String   // JSON array of {role, content, timestamp}
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([visitorId])
  @@index([context])
}

model AutomationRule {
  id          String   @id @default(cuid())
  visitorId   String?
  name        String
  description String?
  trigger     String   // "schedule" | "event" | "manual" | "new_data"
  triggerConfig String // JSON: {cron?: string, eventType?: string, condition?: string}
  actions     String   // JSON array of {type: "clean"|"model"|"report"|"notify", config: {...}}
  isActive    Boolean  @default(true)
  lastRun     DateTime?
  nextRun     DateTime?
  runCount    Int      @default(0)
  lastStatus  String?  // "success" | "error"
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([visitorId])
  @@index([isActive])
  @@index([nextRun])
}

model AutomationLog {
  id          String   @id @default(cuid())
  ruleId      String
  status      String   @default("pending") // "pending" | "running" | "success" | "error"
  input       String?  // JSON: trigger input data
  output      String?  // JSON: action results
  error       String?
  durationMs  Int?
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([ruleId])
  @@index([status])
}

model AiSuggestion {
  id          String   @id @default(cuid())
  visitorId   String?
  context     String   // "workspace" | "leaderboard" | "data_prep" | "modeling" | "reporting"
  category    String   // "next_action" | "insight" | "optimization" | "template" | "learning"
  title       String
  content     String   // JSON: detailed suggestion data
  confidence  Float    @default(0.5)
  isAccepted  Boolean?
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([context])
  @@index([category])
  @@index([createdAt])
}

model UserPreference {
  id            String   @id @default(cuid())
  visitorId     String   @unique
  skillLevel    String   @default("intermediate") // "beginner" | "intermediate" | "expert"
  preferredLang String   @default("en")
  interfaceMode String   @default("standard") // "compact" | "standard" | "advanced"
  recentPages   String?  // JSON array of recent page paths
  frequentActions String? // JSON: {action: count} map
  theme         String   @default("dark")
  aiSensitivity Float    @default(0.7) // 0-1, how proactive AI should be
  notificationsEnabled Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([visitorId])
}

model AiAuditLog {
  id          String   @id @default(cuid())
  visitorId   String?
  action      String   // "suggestion_accepted" | "suggestion_dismissed" | "automation_run" | "ai_query" | "data_access"
  details     String   // JSON: full context of the action
  error       String?  // Error message if action failed
  inputData   String?  // JSON: what data the AI accessed
  outputData  String?  // JSON: what the AI produced
  model       String   @default("default") // which AI model was used
  tokensUsed  Int?
  durationMs  Int?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([action])
  @@index([createdAt])
}